{
    "name": "apify-github-actions",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
      "lint": "oxlint .",
      "lint:fix": "oxlint . --fix",
      "test": "vitest --run .",
      "type-check": "tsc --noEmit"
    },
    "devDependencies": {
        "@actions/core": "^3.0.1",
        "@actions/github": "^9.1.1",
        "@apify/oxlint-config": "0.2.10",
        "@octokit/rest": "^22.0.1",
        "@types/node": "^25.7.0",
        "oxlint": "1.64.0",
        "oxlint-tsgolint": "0.22.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.6"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "onFail": "error"
        },
        "packageManager": {
            "name": "pnpm",
            "onFail": "error",
            "version": "11.1.1"
        }
    }
}
